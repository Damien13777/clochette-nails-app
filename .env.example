# =============================================================
# Clochette Nails — Template variables d'environnement
# Copier ce fichier vers .env.local et remplir les valeurs.
# .env.local est gitignored.
# =============================================================

# ── Base ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NODE_ENV="development"

# ── Database (Postgres) ───────────────────────────────────────
# Format : postgresql://user:password@host:port/dbname
DATABASE_URL="postgresql://clochette_user:CHANGE_ME@localhost:5432/clochette_dev"

# ── NextAuth v5 (admin auth) ──────────────────────────────────
# Génère un secret avec : openssl rand -base64 32
AUTH_SECRET="CHANGE_ME"
AUTH_TRUST_HOST="true"

# ── Stripe (test mode pour le dev, live en prod) ──────────────
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Resend (email transactionnel) ─────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY="re_..."
# Adresse "From:" des emails sortants. Format Resend : "Nom <email@domaine.fr>"
# En dev sans domaine vérifié : Resend impose "onboarding@resend.dev"
RESEND_FROM_EMAIL="Clochette Nails <contact@clochette-nails.fr>"
# Email qui reçoit les notifications admin (nouveau RDV, contact, etc.)
# Si vide → fallback "contact@clochette-nails.fr"
ADMIN_NOTIF_EMAIL="contact@clochette-nails.fr"
# Secret Svix pour vérifier les webhooks Resend (tracking newsletter
# opens/clicks/bounces). Format : "whsec_<base64>" — copié depuis
# https://resend.com/webhooks. En dev sans valeur : la vérif est skip.
# OBLIGATOIRE en production (sinon endpoint refusé 503).
RESEND_WEBHOOK_SECRET=""

# ── reCAPTCHA v3 ──────────────────────────────────────────────
# Crée un site reCAPTCHA v3 sur https://www.google.com/recaptcha/admin
# La clé de site est PUBLIQUE (exposée au client) → préfixe NEXT_PUBLIC_.
# Sans clés : la vérif est skip (dev) ; honeypot + rate-limit restent actifs.
# En prod : les deux obligatoires (sinon les formulaires sont rejetés).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""

# ── Cron jobs (auth via header `Authorization: Bearer <CRON_SECRET>`) ──
CRON_SECRET="CHANGE_ME"

# ── Factures (optionnel) ──────────────────────────────────────
# Racine de stockage des PDFs de facture. Défaut : private/uploads/invoices/
# (utilisée par les tests pour rediriger vers un dossier temporaire).
# INVOICES_DIR=""

# ── ERP — canal 1 (dispatch des events métier vers l'ERP) ─────
# La queue OutboundEvent n'est ACTIVE que si MANAGEMENT_API_URL est posé (sinon
# emitOutboundEvent = log-only, aucune row). Le dispatcher POST vers
# ${MANAGEMENT_API_URL}/api/v1/incoming/${OUTBOUND_SITE_ID}, signé HMAC.
#   MANAGEMENT_API_URL         = origine de l'ERP (prod : https://gestion.clochette-nails.fr)
#   MANAGEMENT_API_HMAC_SECRET = doit être IDENTIQUE au MANAGEMENT_API_HMAC_SECRET côté ERP
#   OUTBOUND_SITE_ID           = slug de l'instance (défaut "clochette-nails")
# En prod : + crontab */2 sur /api/v1/cron/dispatch-outbound-events (Bearer CRON_SECRET).
MANAGEMENT_API_URL=""
MANAGEMENT_API_HMAC_SECRET=""
OUTBOUND_SITE_ID="clochette-nails"

# ── Google Analytics 4 (chargé uniquement après consentement RGPD) ──
# Format : G-XXXXXXXXXX, obtenu sur https://analytics.google.com
# Laisser vide en dev pour ne pas tracker tes propres clics.
NEXT_PUBLIC_GA_TRACKING_ID=""

# ── Google Search Console (vérif via meta tag dans le <head>) ──
# Token à récupérer sur https://search.google.com/search-console
# (Méthode "Balise HTML" → copier la valeur du content=)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""

# ── Sentry (monitoring d'erreurs) ─────────────────────────────
# DSN public (côté client + serveur). Vide = Sentry no-op (désactivé).
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
# Upload des source maps au build (stack traces lisibles en prod). À définir
# uniquement sur l'environnement de build (VPS). Le token est un SECRET.
#   SENTRY_ORG     = slug de l'organisation (URL Sentry)
#   SENTRY_PROJECT = slug du projet
#   SENTRY_URL     = https://de.sentry.io (région EU) — sinon défaut US
#   SENTRY_AUTH_TOKEN = Organization Auth Token (Settings → Auth Tokens)
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_URL="https://de.sentry.io"
SENTRY_AUTH_TOKEN=""

# ── ERP (canal 2 — recherche cliente en lecture) ──────────────
# Interroge l'ERP pour l'autocomplétion de la modale de résa admin + la page
# /admin/clientes. Le secret ne quitte jamais le serveur (proxy server actions).
# Vides = fonctionnalité désactivée proprement (fail-soft, saisie manuelle).
#   ERP_QUERY_URL    = base URL de l'ERP (dev : http://127.0.0.1:3002)
#   ERP_QUERY_SECRET = doit être IDENTIQUE au ERP_QUERY_SECRET côté ERP
ERP_QUERY_URL=""
ERP_QUERY_SECRET=""
